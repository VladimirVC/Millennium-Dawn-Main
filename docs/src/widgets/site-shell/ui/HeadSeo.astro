---
import faviconPng from "@/assets/images/favicon.png";
import type { SeoMeta } from "@/shared/lib/seo";
import { buildContentSecurityPolicy, serializeJsonLd } from "@/shared/lib/seo";
import { buildThemeBootstrapScript } from "@/shared/lib/theme";
import { toAbsolute, withBase } from "@/shared/lib/routing/urls";
import { SITE_DESCRIPTION, SITE_LANGUAGE, SITE_ORGANIZATION_NAME, SITE_TITLE } from "@/shared/config/site";

interface Props {
  seo: SeoMeta;
}

const { seo }: Props = Astro.props;

// In dev mode Astro renders per-request so Astro.url reflects localhost —
// use that origin so OG preview extensions can reach the image locally.
// (preview mode serves pre-built HTML with production URLs; that's by design.)
const isLocalHost = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
const ogImageUrl = seo.image
  ? isLocalHost
    ? `${Astro.url.origin}${withBase(seo.image.path)}`
    : toAbsolute(seo.image.path)
  : undefined;

const websiteJsonLd = serializeJsonLd({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  url: toAbsolute("/"),
  inLanguage: SITE_LANGUAGE,
});

const organizationJsonLd = serializeJsonLd({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_ORGANIZATION_NAME,
  url: toAbsolute("/"),
  logo: toAbsolute(faviconPng.src),
  description: SITE_DESCRIPTION,
});

const themeBootstrapScript = buildThemeBootstrapScript();
const contentSecurityPolicy = buildContentSecurityPolicy();
const ogType = seo.ogType ?? "website";
const extraJsonLd = seo.extraJsonLd ?? [];
---

<meta charset="UTF-8" />
<meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>{seo.title}</title>

{
  seo.seoEnabled && (
    <>
      <meta name="description" content={seo.description} />
      <link rel="canonical" href={seo.canonical} />

      <meta property="og:site_name" content={SITE_TITLE} />
      <meta property="og:type" content={ogType} />
      <meta property="og:title" content={seo.title} />
      <meta property="og:description" content={seo.description} />
      <meta property="og:url" content={seo.canonical} />
      {ogType === "article" && seo.article?.publishedTime && (
        <meta property="article:published_time" content={seo.article.publishedTime} />
      )}
      {ogType === "article" && seo.article?.modifiedTime && (
        <meta property="article:modified_time" content={seo.article.modifiedTime} />
      )}
      {ogType === "article" && seo.article?.author && <meta property="article:author" content={seo.article.author} />}
      {seo.image && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          {seo.image.width && <meta property="og:image:width" content={String(seo.image.width)} />}
          {seo.image.height && <meta property="og:image:height" content={String(seo.image.height)} />}
          {seo.image.alt && <meta property="og:image:alt" content={seo.image.alt} />}
        </>
      )}

      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={seo.title} />
      <meta name="twitter:description" content={seo.description} />
      {seo.image && <meta name="twitter:image" content={ogImageUrl} />}
      {seo.image?.alt && <meta name="twitter:image:alt" content={seo.image.alt} />}

      <script type="application/ld+json" set:html={websiteJsonLd} is:inline />
      <script type="application/ld+json" set:html={organizationJsonLd} is:inline />
      {extraJsonLd.map((jsonLd) => (
        <script type="application/ld+json" set:html={serializeJsonLd(jsonLd)} is:inline />
      ))}
    </>
  )
}

{seo.robots && <meta name="robots" content={seo.robots} />}

<script is:inline set:html={themeBootstrapScript} />

<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={toAbsolute("/feed.xml")} />
<link rel="icon" type="image/png" href={withBase(faviconPng.src)} />
