---
import ResponsiveImage from "@/shared/ui/ResponsiveImage.astro";
import { stripBase, withBase } from "@/shared/lib/routing/urls";
import {
  getLocalImageDimensions,
  getLocalRasterDimensionsSyncFromUrl,
} from "@/shared/lib/media/local-image-dimensions";
import { getInternalImageAsset } from "@/shared/lib/media/image-assets";

interface Props {
  src: string;
  alt?: string;
  class?: string;
  width?: number | string;
  height?: number | string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  title?: string;
}

const {
  src,
  alt = "",
  class: className,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  title,
}: Props = Astro.props;

function parseDimension(value: number | string | undefined): number | undefined {
  if (typeof value === "number") return Number.isFinite(value) ? value : undefined;
  if (typeof value === "string") {
    const t = value.trim();
    if (/^\d+$/.test(t)) return Number(t);
    const px = /^(\d+)px$/i.exec(t);
    if (px) return Number(px[1]);
  }
  return undefined;
}

const explicitWidth = parseDimension(width);
const explicitHeight = parseDimension(height);
/** Paths are often prefixed with `SITE_BASE` by remark; public disk + asset map use root-relative `/assets/...`. */
const assetSrc = stripBase(src);
const internalAsset = getInternalImageAsset(assetSrc);
/** Prefer `src/assets` metadata whenever the file is in the glob map — even if rehype already injected width/height (see `rehypeImageDimensions`). */
let inferredDimensions: { width: number; height: number } | null | undefined = internalAsset
  ? { width: internalAsset.width, height: internalAsset.height }
  : await getLocalImageDimensions(assetSrc);
if (!inferredDimensions && !internalAsset) {
  inferredDimensions = getLocalRasterDimensionsSyncFromUrl(assetSrc) ?? getLocalRasterDimensionsSyncFromUrl(src);
}
const resolvedWidth = explicitWidth ?? inferredDimensions?.width;
const resolvedHeight = explicitHeight ?? inferredDimensions?.height;
const resolvedClassName = className?.trim();
const canUseResponsiveImage = Boolean(resolvedWidth && resolvedHeight);
const isDecorative = !alt || alt.trim() === "";
const imgAttrs = isDecorative ? { "aria-hidden": "true" as const, role: "presentation" as const } : {};
/** Unoptimized file URL for lightbox zoom (same path as markdown, not Astro `srcset` pick). */
const ABSOLUTE_SCHEME = /^[a-zA-Z][a-zA-Z0-9+.-]*:/;
const lightboxFullSrc =
  canUseResponsiveImage && assetSrc.startsWith("/") && !assetSrc.startsWith("//") && !ABSOLUTE_SCHEME.test(assetSrc)
    ? withBase(assetSrc)
    : undefined;
---

{
  canUseResponsiveImage ? (
    <ResponsiveImage
      src={internalAsset ?? assetSrc}
      alt={alt}
      decorative={isDecorative}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      wrapperClass={resolvedClassName}
      class={resolvedClassName}
      lightboxFullSrc={lightboxFullSrc}
    />
  ) : (
    <img
      src={withBase(src)}
      alt={alt}
      {...imgAttrs}
      class={resolvedClassName}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      title={title}
    />
  )
}
