# Sprites for the tokenized topbar counter widget.
# Chrome sprites adapted from Black Ice; token-icon aliases reuse the existing
# GFX_topbar_* textures in Counter_UI.gfx. See common/scripted_guis/BI_dynamic_topbar.txt.
spriteTypes = {

	# --- Chrome ---
	spriteType = {
		name = "GFX_selected_topbar_slot"
		texturefile = "gfx/interface/topbar/dynamic_topbar/selected_topbar_slot_highlight.dds"
		noOfFrames = 3
	}
	spriteType = {
		name = "GFX_topbar_menu_bg"
		texturefile = "gfx/interface/topbar/dynamic_topbar/topbar_menu_bg.dds"
	}
	spriteType = {
		name = "GFX_bice_button_24"
		texturefile = "gfx/interface/topbar/dynamic_topbar/topbar_blank.dds"
	}
	spriteType = {
		name = "GFX_transparent_40_18"
		texturefile = "gfx/interface/topbar/dynamic_topbar/topbar_blank.dds"
	}
	spriteType = {
		name = "GFX_expand_button"
		texturefile = "gfx/interface/topbar/dynamic_topbar/expand_button.dds"
	}

	# --- Token icon aliases (chip icon = GFX_<token>) ---
	spriteType = { name = "GFX_topbar_empty" texturefile = "gfx/interface/topbar/dynamic_topbar/topbar_blank.dds" }
