	# Songun Naval Doctrine — thematic track headers + tier markers.
	# Track header (large, left side) + 4 tier markers (small, along the row)
	# all alias the same tech icon per track for visual consistency.
	#  sub  -> 2040 missile submarine hull (Stormbringer)
	#  mb   -> 2005 destroyer hull (AB F2)
	#  cd   -> NSB defense doctrine tech (gen3 helicopter defense system art)
	#  so   -> generic special forces tech tier 5
	#  caps -> NKO red dawn focus icon
	SpriteType = {
		name = "GFX_NKO_naval_buildup_sub_marker"
		texturefile = "gfx/interface/technologies/USA/NAV/Stormbringer.dds"
	}
	SpriteType = {
		name = "GFX_NKO_naval_buildup_mb_marker"
		texturefile = "gfx/interface/technologies/USA/NAV/AB_F2.dds"
	}
	SpriteType = {
		name = "GFX_NKO_naval_buildup_cd_marker"
		texturefile = "gfx/interface/technologies/0_generic/Engineer_Support_Equipment.dds"
	}
	SpriteType = {
		name = "GFX_NKO_naval_buildup_so_marker"
		texturefile = "gfx/interface/technologies/0_generic/Land_Doctrines/marines_commandoes_medium.dds"
	}
	SpriteType = {
		name = "GFX_NKO_naval_buildup_capstone"
		texturefile = "gfx/interface/goals/north_korea/NKO_red_dawn.dds"
	}

