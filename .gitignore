###############################################################################
# Python
###############################################################################
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
pythontools.log

###############################################################################
# Node / Docs (Astro)
###############################################################################
node_modules/
docs/dist/
docs/.astro/
docs/assets/images/seo/generated/
*.css.map

# Allow tracked docs frontend/runtime scripts
!docs/src/scripts/
!docs/src/scripts/*.ts
!docs/src/scripts/**/*.js
!docs/assets/downloads/tools/
!docs/assets/downloads/tools/*.zip
!docs/scripts/
!docs/scripts/*.py
!docs/eslint.config.js

###############################################################################
# IDE / editor
###############################################################################
.vscode/
.vs/
.idea/
.continue/
.opencode/
vscode-userdata:/

###############################################################################
# Claude Code
###############################################################################
.claire/
.claude/worktrees/
.claude/agent-memory/
.claude/settings.local.json
.md-mcp-cache/

## Used for reporting/markdown creating that we don't want permanently in code
specs/

###############################################################################
# Tooling / analysis
###############################################################################
repomix-*.xml

###############################################################################
# OS
###############################################################################
.DS_Store

###############################################################################
# Photoshop source files (not for distribution)
###############################################################################
*.psd

