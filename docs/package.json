{
  "name": "millennium-dawn-docs",
  "private": false,
  "version": "1.0.1",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"src/content/**/*.md\" \"src/content/**/*.mdx\"",
    "lint:remark": "remark \"src/content/**/*.md\" \"src/content/**/*.mdx\" --frail",
    "check:links": "bun scripts/run_site_python_check.ts scripts/check_site_links.py --site-dir dist",
    "check:og": "bun scripts/run_site_python_check.ts scripts/check_og_images.py --site-dir dist",
    "check:a11y": "python scripts/check_accessibility_basics.py --site-dir dist",
    "check:perf": "python scripts/check_perf_budgets.py --site-dir dist",
    "check:content-html": "python scripts/check_content_html.py",
    "check:flags": "python scripts/check_flag_images.py",
    "ci": "bun run lint:md && bun run lint:remark && bun run check:content-html && bun run check:flags && bun run check && bun run build && bun run check:og && bun run check:links && bun run check:a11y && bun run check:perf"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.5",
    "image-size": "^2.0.2",
    "rehype-external-links": "^3.0.0",
    "rehype-sanitize": "^6.0.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "smol-toml": "^1.6.1",
    "brace-expansion@2": "2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "remark-cli": "^12.0.1",
    "remark-directive": "^4.0.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "typescript-eslint": "^8.61.0",
    "unist-util-visit": "^5.1.0"
  }
}
