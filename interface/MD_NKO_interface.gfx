	# Songun Naval Doctrine progress bar — driven by NKO_<track>_progress (0–100).
	# Reused 4 times in the GUI, one per track. frame value = variable value.
	progressbartype = {
		name = "GFX_NKO_naval_buildup_progress_bar"
		textureFile1 = "gfx/interface/autonomy/subject_progress_bar_long.dds"
		textureFile2 = "gfx/interface/autonomy/subject_progress_bar_long_bg.dds"
		size = { x = 240 y = 16 }
		effectFile = "gfx/FX/progress.lua"
		steps = 100
	}

	# Small tier-marker dot — alias of the NKO red dawn star, rendered along
	# each track row to indicate which tier (1-4) the player has crossed.
	# Visibility is gated by per-tier flags in the scripted_gui triggers block.
	SpriteType = {
		name = "GFX_NKO_naval_tier_marker"
		texturefile = "gfx/interface/goals/north_korea/NKO_red_dawn.dds"
