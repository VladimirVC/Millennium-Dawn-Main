			maxHeight = 18
		}
		instantTextBoxType = { name = "NKO_so_buffs_none"   position = { x = 305 y = 352 } font = "hoi_14mbs" text = "NKO_so_buffs_none"   format = left maxWidth = 184 maxHeight = 84 }
		instantTextBoxType = { name = "NKO_so_buffs_tier_1" position = { x = 305 y = 352 } font = "hoi_14mbs" text = "NKO_so_buffs_tier_1" format = left maxWidth = 184 maxHeight = 84 }
