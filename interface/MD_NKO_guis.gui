		instantTextBoxType = { name = "NKO_so_current_none"   position = { x = 12 y = 376 } font = "hoi_14mbs" text = "NKO_so_current_none"   format = left maxWidth = 280 maxHeight = 18 }
		instantTextBoxType = { name = "NKO_so_current_tier_1" position = { x = 12 y = 376 } font = "hoi_14mbs" text = "NKO_so_current_tier_1" format = left maxWidth = 280 maxHeight = 18 }
