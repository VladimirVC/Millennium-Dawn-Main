	spriteType = { name = "GFX_topbar_war_support" texturefile = "gfx/texticons/modifier_icons/war_support_modifiericons_texticon.dds" }
	spriteType = { name = "GFX_topbar_political_power_daily" texturefile = "gfx/interface/topbar/dynamic_topbar/topbar_pp.tga" }
