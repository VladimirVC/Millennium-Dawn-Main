{
  "name": "millennium-dawn-docs",
  "private": false,
  "version": "1.0.1",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"src/content/**/*.md\" \"src/content/**/*.mdx\"",
    "check:links": "python3 ../tools/docs_checks/check_docs.py --no-build --only links",
    "check:og": "python3 ../tools/docs_checks/check_docs.py --no-build --only og",
    "check:a11y": "python3 ../tools/docs_checks/check_docs.py --no-build --only a11y",
    "check:perf": "python3 ../tools/docs_checks/check_docs.py --no-build --only perf",
    "check:content-html": "python3 ../tools/docs_checks/check_docs.py --no-build --only content-html",
    "check:flags": "python3 ../tools/docs_checks/check_docs.py --no-build --only flags",
    "check:link-syntax": "python3 ../tools/docs_checks/check_docs.py --no-build --only link-syntax",
    "check:all": "python3 ../tools/docs_checks/check_docs.py --no-build",
    "ci": "python3 ../tools/docs_checks/check_docs.py"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "image-size": "^2.0.2",
    "rehype-external-links": "^3.0.0",
    "rehype-sanitize": "^6.0.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.1"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "smol-toml": "^1.6.1",
    "brace-expansion@2": "2.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "globals": "^17.6.0",
    "js-yaml": "^5.0.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "remark-directive": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "unist-util-visit": "^5.1.0"
  }
}
